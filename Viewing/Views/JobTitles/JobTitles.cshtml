@model List<Viewing.Models.JobTitle>

@{
    Layout = null; // partial inside Dashboard
}

<div class="container-fluid px-4 py-3">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center p-3 px-4" style="background-color:#6c63ff;">
            <h5 class="text-white mb-0 fw-semibold">Job Titles</h5>
            <button class="btn btn-light btn-sm fw-semibold shadow-sm" data-bs-toggle="modal" data-bs-target="#createJobTitleModal">
                + Create New
            </button>
        </div>

        <!-- Table -->
        <div class="card-body bg-light">
            <div class="table-responsive">
                <table id="jobTitlesTable" class="table table-borderless align-middle mb-0" style="width:100%;">
                    <thead>
                        <tr class="text-uppercase text-secondary small fw-semibold border-bottom">
                            <th>#</th>
                            <th>Job Title</th>
                            <th>Description</th>
                            <th>DepartmentName</th>
                            <th>Seniority</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white">
                        @if (Model != null && Model.Any())
                        {
                            int counter = 1;
                            foreach (var jt in Model)
                            {
                                <tr>
                                    <td>@counter</td>
                                    <td>@jt.Title</td>
                                    <td>@jt.Description</td>
                                    <td>@jt.DepartmentName</td>
                                    <td>@jt.Seniority</td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1">Edit</button>
                                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3">Delete</button>
                                    </td>
                                </tr>
                                counter++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No job titles available</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Create Job Title Modal -->
<div class="modal fade" id="createJobTitleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header" style="background-color:#6c63ff; color:white;">
                <h5 class="modal-title fw-semibold">Create Job Title</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Job Title</label>
                    <input type="text" class="form-control form-control-lg rounded-3" placeholder="Enter job title" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea class="form-control form-control-lg rounded-3" placeholder="Enter description"></textarea>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" style="background-color:#6c63ff; border:none;">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- DataTables CSS & JS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<script>
    $(document).ready(function () {
        $('#jobTitlesTable').DataTable({
            paging: true,
            ordering: true,
            searching: true,
            pageLength: 5,
            language: {
                search: "_INPUT_",
                searchPlaceholder: "Search job titles..."
            }
        });
    });
</script>

<style>
    .dataTables_wrapper .dataTables_filter {
        float: right;
        text-align: right;
        margin-bottom: 1rem;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button {
        border-radius: 50%;
        padding: 0.4rem 0.8rem;
        margin: 0 2px;
    }

    .dataTables_wrapper .dataTables_info {
        font-size: 0.875rem;
        color: #6c757d;
        margin-top: 0.5rem;
    }

    .dataTables_wrapper .dataTables_paginate {
        margin-top: 0.5rem;
    }

    .table > thead > tr > th {
        border-bottom: 2px solid #dee2e6;
    }

    .table > tbody > tr:hover {
        background-color: #f8f9fa;
        transition: background-color 0.3s ease;
    }
</style>